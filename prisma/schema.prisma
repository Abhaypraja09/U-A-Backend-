generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  staffId    String?  @unique
  name       String
  email      String   @unique
  password   String
  role       String   @default("employee")
  department String?
  status     String   @default("active")
  wage       Float?   @default(0)
  otRate     Float?   @default(0)
  pieceRate  Float?   @default(0) // Rate per Sq.Ft.
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  projects       Project[] @relation("AssignedProjects")
  leads          Lead[]    @relation("AssignedLeads")
  productionLogs ProductionLog[]
  attendances    Attendance[]
  payrolls       Payroll[]
  qaInspections  QA_QC[]
  machineLogs    MachineLog[]
  expenses       Expense[]
}

model Project {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String   @unique
  clientId    String?  @db.ObjectId
  
  // Enquiry specific fields
  clientName   String?
  clientContact String?
  clientEmail  String?
  customerPhoto String?
  enquirySource String?  // WhatsApp, Website, Call, Architect, etc.
  location     String?
  requirements String?
  
  name        String
  description String?
  status      String   @default("enquiry") // enquiry, design_sharing, design_finalized, quotation, advance_payment, work_order, completed
  startDate   DateTime?
  deadline    DateTime?
  progressPercentage Float @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignedToId String? @db.ObjectId
  assignedTo   User?   @relation("AssignedProjects", fields: [assignedToId], references: [id])
  
  // Work Order specific metrics
  totalPieces       Int @default(0)
  completedPieces   Int @default(0)
  deliveryDate      DateTime?
  clientHandle      String?

  designFiles    String[] @default([])
  receiptUrl     String?
  workOrderUrl   String?

  designs        Design[]
  shopDrawings   ShopDrawing[]
  approvals      ApprovalRecord[]
  quotations     Quotation[]
  invoices       Invoice[]
  productionLogs ProductionLog[]
  crates         Crate[]
  dispatches     Dispatch[]
  qaRecords      QA_QC[]
  machineLogs    MachineLog[]
  laborContracts LaborContract[]
  materials      ProjectMaterial[]
  projectClosure ProjectClosure?
}

model ProjectMaterial {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String   @db.ObjectId
  project     Project  @relation(fields: [projectId], references: [id])
  inventoryId String   @db.ObjectId
  inventory   Inventory @relation(fields: [inventoryId], references: [id])
  quantity    Float
  cost        Float
  addedAt     DateTime @default(now())
}

model Lead {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  clientName   String
  contact      String
  email        String?
  source       String
  architect    String?
  designer     String?
  status       String   @default("new")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedToId String?  @db.ObjectId
  assignedTo   User?    @relation("AssignedLeads", fields: [assignedToId], references: [id])
}

model Design {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId      String   @db.ObjectId
  project        Project  @relation(fields: [projectId], references: [id])
  cadUrl         String?
  drawingUrl     String?
  renderUrl      String?
  revisionNumber Int      @default(1)
  status         String   @default("pending")
  isFrozen       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ShopDrawing {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId      String   @db.ObjectId
  project        Project  @relation(fields: [projectId], references: [id])
  title          String
  type           String   // Shop Drawing, Production Drawing, 3D Render
  fileUrl        String
  version        Int      @default(1)
  status         String   @default("Pending") // Pending, Approved, Rejected
  comments       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  approvals      ApprovalRecord[]
}

model ApprovalRecord {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId      String   @db.ObjectId
  project        Project  @relation(fields: [projectId], references: [id])
  shopDrawingId  String   @db.ObjectId
  shopDrawing    ShopDrawing @relation(fields: [shopDrawingId], references: [id])
  approvedBy     String   // Client Name or person approving
  status         String   // Approved, Rejected, Changes Requested
  notes          String?
  date           DateTime @default(now())
}

model Quotation {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId        String   @db.ObjectId
  project          Project  @relation(fields: [projectId], references: [id])
  materialCost     Float    @default(0)
  cncCost          Float    @default(0)
  handCarvingCost  Float    @default(0)
  inlayCost        Float    @default(0)
  polishingCost    Float    @default(0)
  packingCost      Float    @default(0)
  transportCost    Float    @default(0)
  installationCost Float    @default(0)
  marginPercentage Float    @default(0)
  totalCost        Float    @default(0)
  finalAmount      Float    @default(0)
  products         Json?
  status           String   @default("draft") // draft, sent, approved, rejected
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Invoice {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId      String   @db.ObjectId
  project        Project  @relation(fields: [projectId], references: [id])
  invoiceNumber  String   @unique
  totalAmount    Float    @default(0)
  advancePaid    Float    @default(0)
  balanceAmount  Float    @default(0)
  status         String   @default("unpaid")
  paymentMethod  String?
  paymentDate    DateTime?
  issueDate      DateTime @default(now())
  dueDate        DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ProductCategory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  createdAt DateTime @default(now())
}

model UnitCategory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  createdAt DateTime @default(now())
}

model Inventory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String   // block, slab, consumable
  jobWorkType String   @default("company") // company, client
  itemName    String
  
  // Dimensions for blocks/slabs
  blockNumber String?
  thickness   Float?
  length      Float?
  width       Float?
  height      Float?
  weight      Float?
  
  quantity    Float    @default(0) // Can be sq_ft or pieces
  unit        String   // sq_ft, pieces, kg, liters, tons
  supplier    String?
  costPerUnit Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  projectMaterials ProjectMaterial[]
}

model Machine {
  id                       String   @id @default(auto()) @map("_id") @db.ObjectId
  name                     String
  type                     String   // CNC, Cutter, Polisher
  status                   String   @default("active") // active, maintenance, inactive
  hourlyCost               Float    @default(0)
  totalRunHours            Float    @default(0)
  maintenanceIntervalHours Float    @default(200)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  
  productionLogs ProductionLog[]
  machineLogs    MachineLog[]
  attendances    Attendance[]
}

model ProductionLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String?  @db.ObjectId
  project     Project? @relation(fields: [projectId], references: [id])
  stage       String   // cutting, cnc, carving, inlay, polishing, packing
  machineId   String?  @db.ObjectId
  machine     Machine? @relation(fields: [machineId], references: [id])
  workerId    String?  @db.ObjectId
  worker      User?    @relation(fields: [workerId], references: [id])
  startTime   DateTime @default(now())
  endTime     DateTime?
  status           String   @default("in_progress") // in_progress, completed, paused
  quantityProduced Float    @default(0) // Sq.Ft. or Pieces produced
  
  // Material Tracking and Workflow Fields
  transactionType  String?  // OUT (Given to staff), IN (Received from staff)
  approvalStatus   String   @default("pending") // pending, approved, rejected
  startPhotos      Json?    // { machine, unit, software }
  vendorName       String?  // If given to outside vendor
  
  remarks          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Crate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  crateNumber String   @unique
  projectId   String   @db.ObjectId
  project     Project  @relation(fields: [projectId], references: [id])
  weight      Float    @default(0)
  status      String   @default("packing")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  dispatchId  String?  @db.ObjectId
  dispatch    Dispatch? @relation(fields: [dispatchId], references: [id])
}

model Dispatch {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId      String   @db.ObjectId
  project        Project  @relation(fields: [projectId], references: [id])
  vehicleNumber  String
  driverDetails  String?
  lrNumber       String?
  lrUrl          String?
  status         String   @default("in_transit")
  dispatchDate   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  crates         Crate[]
}

model Attendance {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime @default(now())
  checkIn     DateTime @default(now())
  checkOut    DateTime?
  machineId   String?  @db.ObjectId
  machine     Machine? @relation(fields: [machineId], references: [id])
  photoUrl    String?
  gpsLocation String?
  status      String   @default("present") // present, absent, half_day
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payroll {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  user           User     @relation(fields: [userId], references: [id])
  month          String
  basicSalary    Float    @default(0)
  incentives     Float    @default(0)
  deductions     Float    @default(0)
  netSalary      Float    @default(0)
  status         String   @default("pending")
  paymentDate    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model QA_QC {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String   @db.ObjectId
  project     Project  @relation(fields: [projectId], references: [id])
  dimensionOk Boolean  @default(false)
  finishOk    Boolean  @default(false)
  crackOk     Boolean  @default(false)
  remarks     String?
  status      String   @default("pending") // pending, passed, failed
  inspectedBy String?  @db.ObjectId
  inspector   User?    @relation(fields: [inspectedBy], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MachineLog {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  machineId        String   @db.ObjectId
  machine          Machine  @relation(fields: [machineId], references: [id])
  projectId        String?  @db.ObjectId
  project          Project? @relation(fields: [projectId], references: [id])
  startTime        DateTime
  endTime          DateTime?
  downtime         Float    @default(0) // hours
  operatorId       String?  @db.ObjectId
  operator         User?    @relation(fields: [operatorId], references: [id])
  machinePhotoUrl  String?
  unitPhotoUrl     String?
  softwarePhotoUrl String?
  endMachinePhotoUrl  String?
  endUnitPhotoUrl     String?
  endSoftwarePhotoUrl String?
  status           String   @default("active") // active, completed
  approvalStatus   String   @default("pending") // pending, approved, rejected
  remarks          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model LaborContract {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId      String   @db.ObjectId
  project        Project  @relation(fields: [projectId], references: [id])
  contractorName String
  jobType        String   // polishing, inlay, carving
  rate           Float
  totalAmount    Float    @default(0)
  paidAmount     Float    @default(0)
  status         String   @default("in_progress")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Expense {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  category    String   // maintenance, consumables, tools, fuel, water, transport, packaging, tea_refreshments, travel, hotel, food, courier, internet, phone, vehicle, miscellaneous
  amount      Float
  description String?
  date        DateTime @default(now())
  paidBy      String?  @db.ObjectId
  user        User?    @relation(fields: [paidBy], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ElectricityLog {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  month          String   // e.g. "2026-06"
  meterReading   Float
  unitsConsumed  Float
  totalBill      Float
  paymentStatus  String   @default("pending") // pending, paid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ProjectClosure {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId        String   @unique @db.ObjectId
  project          Project  @relation(fields: [projectId], references: [id])
  deliveryDate     DateTime
  installationDate DateTime?
  clientFeedback   String?
  rating           Int?     // 1 to 5
  warrantyEnd      DateTime?
  status           String   @default("closed")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
